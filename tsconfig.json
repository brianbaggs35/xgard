{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "app/javascript/**/*.ts",
    "app/javascript/**/*.vue",
    "app/javascript/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
